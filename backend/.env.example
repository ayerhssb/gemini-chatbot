# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — model can be any vision-capable Gemini model
GEMINI_MODEL=gemini-2.0-flash

# Server port
PORT=5000

# CORS — set to your frontend origin in production, "*" for local dev
CORS_ORIGIN=*
